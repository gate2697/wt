PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=change-me-long-random
DATABASE_PATH=./data/app.sqlite

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4000/auth/discord/callback
DISCORD_GUILD_ID=

# Comma-separated role names or IDs. Examples: cbmodperms,1234567890
CB_MOD_PERMS=cbmodperms
CB_HMOD_PERMS=cbhmodperms
CB_HIGHMOD_PERMS=highmodperms

BOT_API_TOKEN=change-me-bot-token

# War Thunder ID resolver. Default uses scripts/resolve_wt_user.py with wt-profile-tool.
# Windows usually uses python. Linux hosts usually use python3.
PYTHON_BIN=python
WT_RESOLVER_SCRIPT=
WT_RESOLVER_TIMEOUT_MS=15000
# true = if lookup fails, still save the ban by username only. false = fail ban creation.
ALLOW_UNRESOLVED_BANS=true

# Optional. Replace with the actual lookup endpoint if StatShark exposes one to you.
# Use {username} in the URL. Example: https://example.com/api/player?name={username}
STATSHARK_LOOKUP_URL=
STATSHARK_API_TOKEN=
